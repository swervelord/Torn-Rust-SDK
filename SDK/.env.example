# Required: one or more keys
TORN_API_KEYS=your_key_1,your_key_2
# Optional fallback for single-key setups
# TORN_API_KEY=your_single_key

# Optional endpoint overrides
TORN_API_BASE_URL_V2=https://api.torn.com/v2
TORN_API_BASE_URL_V1=https://api.torn.com

# Optional transport/retry tuning
TORN_HTTP_TIMEOUT_SECS=30
TORN_USER_AGENT=torn-sdk-rust/0.1
TORN_MAX_ATTEMPTS=3
TORN_NETWORK_RETRY_BACKOFF_MS=250
TORN_MAX_IN_FLIGHT=8

# Optional rate limit overrides
TORN_RATE_LIMIT_PER_KEY_PER_MIN=100
TORN_RATE_LIMIT_PER_IP_PER_MIN=1000

# Optional test helper
TORN_TEST_USER_ID=3637232

# Optional ignored live smoke test variables
# TORN_LIVE_TEST_API_KEY=your_key_here
# TORN_LIVE_TEST_USER_ID=3637232
# TORN_LIVE_TEST_ITEM_ID=1
# TORN_LIVE_TEST_REQUIRE_RUNTIME_FALLBACK=false
